# ===== 数据库 =====
# MySQL 数据库连接串（用户名:密码@主机:端口/库名?字符集）
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/ai_assistant?charset=utf8mb4

# ===== LLM 模型配置 =====
# 模型 Provider 的 API Key（必填，使用对话功能时需要）
LLM_API_KEY=
# 模型服务的 Base URL（OpenAI 兼容协议）
LLM_BASE_URL=https://api.deepseek.com/v1
# 模型名称
LLM_MODEL_NAME=deepseek-chat

# ===== 安全 =====
# JWT 签名密钥（生产环境必须替换为随机长字符串）
SECRET_KEY=please-change-me-in-production

# ===== 上传 =====
# 文件上传目录
UPLOAD_DIR=./uploads

# ===== 日志 =====
LOG_DIR=./logs
LOG_LEVEL=INFO
