# ===== 数据库 =====
# SQLite 数据库连接串（开发用，单文件零配置）
# 生产环境可换 Postgres：postgresql+psycopg://user:pwd@host:5432/db
DATABASE_URL=sqlite:///./data/ai_assistant.db

# ===== LLM 模型配置 =====
# 模型 Provider 的 API Key（必填，使用对话功能时需要）
LLM_API_KEY=
# 模型服务的 Base URL（OpenAI 兼容协议）
LLM_BASE_URL=https://api.deepseek.com/v1
# 模型名称
LLM_MODEL_NAME=deepseek-chat

# ===== 安全 =====
# JWT 签名密钥（生产环境必须替换为随机长字符串）
SECRET_KEY=please-change-me-in-production

# ===== 上传 =====
# 文件上传目录
UPLOAD_DIR=./uploads

# ===== 日志 =====
LOG_DIR=./logs
LOG_LEVEL=INFO

# ===== LangSmith 追踪（调试 Agent 用，可选）=====
# 注册地址：https://smith.langchain.com/
# Settings → API Keys → Create API Key
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=ai-assistant
